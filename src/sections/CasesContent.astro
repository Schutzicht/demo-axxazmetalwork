---
import { useTranslations, localizePath } from '../i18n/utils';
import { cases } from '../data/site';
import type { Lang } from '../i18n/ui';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const isEn = lang === 'en';
---
<PageHero kicker={t('cases.kicker')} title={t('cases.title')} sub={t('cases.sub')} />

<section class="section">
  <div class="container-x">
    <div class="grid md:grid-cols-2 gap-6">
      {cases.map(cs => (
        <a href={localizePath(lang, `/cases/${cs.slug}`)} class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line)] bg-white hover:border-[var(--color-axxaz-navy)] hover:-translate-y-1 hover:shadow-[0_24px_60px_-24px_rgba(14,26,61,0.2)] transition-all duration-300" data-reveal>
          <div class="relative aspect-[16/9] overflow-hidden">
            <img src={cs.cover} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
            <div class="absolute bottom-4 left-5 right-5 text-white">
              <div class="text-[10px] uppercase tracking-widest font-bold opacity-90">{cs.industry} · {cs.location}</div>
              <div class="text-2xl font-bold mt-1">{cs.client}</div>
            </div>
          </div>
          <div class="p-7 flex flex-col flex-grow">
            <h3 class="text-xl leading-snug group-hover:text-[var(--color-axxaz-navy)] transition-colors">{isEn ? cs.titleEn : cs.titleNl}</h3>
            <p class="mt-3 text-sm flex-grow truncate-3">{isEn ? cs.excerptEn : cs.excerptNl}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {(isEn ? cs.metricsEn : cs.metricsNl).slice(0, 2).map(m => <span class="chip">{m}</span>)}
            </div>
            <div class="mt-5 inline-flex items-center gap-1.5 font-semibold text-sm text-[var(--color-spark)]">
              {t('cases.cta')} <Icon name="arrow-right" size={13} stroke={2.5} />
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
