---
import { useTranslations, localizePath } from '../i18n/utils';
import { site, founders, certifications, facebookFeed, linkedinFeed, vacancies, vakgebieden, reviews, reviewSummary, blogPosts, trustClients, cases } from '../data/site';
import type { Lang } from '../i18n/ui';
import Icon from '../components/Icon.astro';
import ClientLogo from '../components/ClientLogo.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const urgentVacs = vacancies.filter(v => v.urgent).slice(0, 3);
const validCerts = certifications.slice(0, 6);
const totalVacs = vacancies.length + 38;

const services = [
  { title: t('services.uitzenden.title'), items: [t('services.uitzenden.i1'), t('services.uitzenden.i2'), t('services.uitzenden.i3')] },
  { title: t('services.werving.title'), items: [t('services.werving.i1'), t('services.werving.i2'), t('services.werving.i3')] },
  { title: t('services.detachering.title'), items: [t('services.detachering.i1'), t('services.detachering.i2'), t('services.detachering.i3')] },
];

const vakLabels: Record<string, string> = {
  'lassen-mig-mag': t('vak.lassenMigMag'),
  'lassen-tig': t('vak.lassenTig'),
  'pijpfitten': t('vak.pijpfitten'),
  'constructiebankwerk': t('vak.constructie'),
  'plaatwerk': t('vak.plaatwerk'),
  'cnc-verspanen': t('vak.cnc'),
  'apparatenbouw': t('vak.apparatenbouw'),
  'monteur-metaal': t('vak.monteur'),
  'staalbouw': t('vak.staalbouw'),
};

const tcBullets = [t('tc.b1'), t('tc.b2'), t('tc.b3'), t('tc.b4')];
---

<!-- HERO -->
<section class="relative overflow-hidden bg-[var(--color-paper)]">
  <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-32 w-[42rem] h-[42rem] rounded-full bg-[var(--color-spark)]/[0.06] blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-[40rem] h-[40rem] rounded-full bg-[var(--color-axxaz-blue)]/[0.08] blur-3xl"></div>
  </div>

  <div class="relative z-10 container-x pt-24 sm:pt-28 md:pt-32 lg:pt-36 pb-14 sm:pb-20 md:pb-24">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 sm:gap-12 lg:gap-20 items-center">
      <!-- LEFT: copy for jobseekers -->
      <div>
        <div class="eyebrow eyebrow-dark">{t('hero.kicker')}</div>
        <h1 class="mt-5 sm:mt-6 text-[2.25rem] sm:text-5xl md:text-6xl lg:text-7xl text-[var(--color-ink)] leading-[0.95] font-extrabold tracking-[-0.04em]">
          {t('hero.titleA')}<br/>
          <span class="text-gradient-spark">{t('hero.titleB')}</span>,<br/>
          {t('hero.titleC')}
        </h1>
        <p class="mt-7 text-base md:text-lg text-[var(--color-ink-soft)] max-w-xl leading-relaxed">{t('hero.sub')}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={localizePath(lang, '/open-sollicitatie')} class="btn btn-primary"><Icon name="send" size={14} stroke={2} /> {t('cta.openSollicitatie')}</a>
          <a href={localizePath(lang, '/werkgevers')} class="btn btn-ghost">{t('cta.zoekWerknemers')} <Icon name="arrow-right" size={14} stroke={2.25} /></a>
        </div>
      </div>

      <!-- RIGHT: vacature search card -->
      <aside class="relative">
        <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-[var(--color-spark)]/10 via-transparent to-[var(--color-axxaz-blue)]/10 blur-2xl pointer-events-none"></div>
        <div class="relative rounded-2xl bg-white border border-[var(--color-line)] p-5 sm:p-6 md:p-8 shadow-[0_24px_60px_-20px_rgba(14,26,61,0.18)]">
          <div class="flex items-baseline justify-between gap-3 mb-1">
            <h2 class="text-2xl md:text-3xl tracking-tight">Direct zoeken</h2>
            <span class="chip chip-ghost text-[10px] font-mono">{totalVacs} open</span>
          </div>

          <form action={localizePath(lang, '/vacatures')} class="mt-6 space-y-3">
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--color-ink-mute)] pointer-events-none">
                <Icon name="briefcase" size={16} stroke={1.75} />
              </span>
              <input type="text" name="q" placeholder={t('hero.searchPlaceholder')}
                     class="field pl-11" />
            </div>
            <div class="grid grid-cols-2 gap-2">
              <select name="loc" class="field">
                <option value="">Alle locaties</option>
                {[...new Set(vacancies.map(v => v.location))].sort().map(l => <option value={l}>{l}</option>)}
              </select>
              <select name="cat" class="field">
                <option value="all">Alle types</option>
                <option value="urgent">Urgent</option>
                <option value="vast">Vast</option>
                <option value="detachering">Detachering</option>
              </select>
            </div>
            <button class="btn btn-spark btn-lg w-full justify-center">
              {t('hero.searchCta').replace('{n}', String(totalVacs))}
              <Icon name="arrow-right" size={15} stroke={2.5} />
            </button>
          </form>

          <div class="mt-6 pt-5 border-t border-[var(--color-line)]">
            <div class="text-[10px] uppercase tracking-widest font-bold text-[var(--color-ink-mute)] mb-3">Populair</div>
            <div class="flex flex-wrap gap-1.5">
              {vakgebieden.slice(0, 5).map(v => (
                <a href={localizePath(lang, `/vacatures?cat=${v.slug}`)}
                   class="chip chip-ghost hover:bg-[var(--color-spark)] hover:border-[var(--color-spark)] hover:text-white transition-colors">
                  {v.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- DUO CTA -->
<section class="-mt-12 md:-mt-20 relative z-20">
  <div class="container-x">
    <div class="grid md:grid-cols-2 gap-4">
      <a href={localizePath(lang, '/vacatures')}
         class="group relative overflow-hidden rounded-2xl bg-[var(--color-axxaz-navy)] aspect-[16/8] sm:aspect-[16/6] md:aspect-[5/3] transition-all duration-500 hover:-translate-y-1.5 shadow-[0_24px_60px_-24px_rgba(14,26,61,0.5)]">
        <img src="/img/site/welding-2.png" alt="" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-65 transition-opacity duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-axxaz-navy-darker)] via-[var(--color-axxaz-navy)]/85 to-transparent"></div>
        <div class="relative z-10 h-full p-7 md:p-10 flex flex-col justify-end text-white">
          <h2 class="text-2xl md:text-3xl lg:text-4xl !text-white tracking-tight">{t('duo.werk.title')}</h2>
          <p class="mt-3 text-white/70 text-sm md:text-base max-w-md leading-relaxed">{t('duo.werk.sub')}</p>
          <div class="mt-6 inline-flex items-center gap-2.5 font-semibold">
            {t('duo.werk.cta')}
            <span class="bg-[var(--color-spark)] rounded-full w-9 h-9 inline-flex items-center justify-center group-hover:translate-x-1 transition-transform shadow-[0_8px_20px_-4px_rgba(232,93,31,0.5)]">
              <Icon name="arrow-right" size={15} stroke={2.5} />
            </span>
          </div>
        </div>
      </a>
      <a href={localizePath(lang, '/werkgevers')}
         class="group relative overflow-hidden rounded-2xl bg-[var(--color-spark-deep)] aspect-[16/8] sm:aspect-[16/6] md:aspect-[5/3] transition-all duration-500 hover:-translate-y-1.5 shadow-[0_24px_60px_-24px_rgba(184,65,15,0.5)]">
        <img src="/img/site/workshop-3.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-65 transition-opacity duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-spark-deep)] via-[var(--color-spark-deep)]/80 to-transparent"></div>
        <div class="relative z-10 h-full p-7 md:p-10 flex flex-col justify-end text-white">
          <h2 class="text-2xl md:text-3xl lg:text-4xl !text-white tracking-tight">{t('duo.personeel.title')}</h2>
          <p class="mt-3 text-white/85 text-sm md:text-base max-w-md leading-relaxed">{t('duo.personeel.sub')}</p>
          <div class="mt-6 inline-flex items-center gap-2.5 font-semibold">
            {t('duo.personeel.cta')}
            <span class="bg-white text-[var(--color-spark-deep)] rounded-full w-9 h-9 inline-flex items-center justify-center group-hover:translate-x-1 transition-transform shadow-lg">
              <Icon name="arrow-right" size={15} stroke={2.5} />
            </span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- TRUST STRIP, auto-scrolling marquee -->
<section class="border-y border-[var(--color-line)] bg-white mt-16 md:mt-24" data-reveal>
  <div class="py-9 md:py-11">
    <div class="marquee">
      <div class="marquee-track">
        {[...trustClients, ...trustClients].map(c => (
          <ClientLogo name={c.name} domain={c.domain} slug={c.slug} logo={c.logo} industry={c.industry} />
        ))}
      </div>
    </div>
  </div>
</section>

<!-- BIG STATS, horizontale rij met dunne dividers -->
<section class="section" data-reveal>
  <div class="container-x">
    <div class="max-w-2xl mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl">{t('stats.title')}</h2>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-y lg:divide-y-0 divide-[var(--color-line)] border border-[var(--color-line)] rounded-2xl overflow-hidden">
      <div class="p-6 sm:p-8 md:p-10">
        <div class="stat-num text-4xl sm:text-5xl md:text-6xl">22<span class="text-[var(--color-spark)]">+</span></div>
        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-mute)]">{t('stats.years')}</p>
      </div>
      <div class="p-6 sm:p-8 md:p-10">
        <div class="stat-num text-4xl sm:text-5xl md:text-6xl">{site.europeOffices + site.asiaOffices}</div>
        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-mute)]">{t('stats.offices')}</p>
      </div>
      <div class="p-6 sm:p-8 md:p-10">
        <div class="stat-num text-4xl sm:text-5xl md:text-6xl">100<span class="text-[var(--color-spark)]">%</span></div>
        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-mute)]">{t('stats.tested')}</p>
      </div>
      <div class="p-6 sm:p-8 md:p-10">
        <div class="stat-num text-4xl sm:text-5xl md:text-6xl">14<span class="text-[var(--color-spark)] text-2xl sm:text-3xl ml-1">{t('stats.placementUnit')}</span></div>
        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-mute)]">{t('stats.placement')}</p>
      </div>
    </div>
  </div>
</section>

<!-- 3 SERVICES -->
<section class="section border-t border-[var(--color-line)]">
  <div class="container-x">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
      <div class="max-w-xl">
        <div class="eyebrow">{t('services.kicker')}</div>
        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl">{t('services.title')}</h2>
      </div>
      <a href={localizePath(lang, '/werkgevers')} class="text-[var(--color-spark)] hover:text-[var(--color-spark-deep)] font-semibold inline-flex items-center gap-1.5 text-sm">{t('services.all')} <Icon name="arrow-right" size={14} stroke={2.25} /></a>
    </div>
    <div class="grid md:grid-cols-3 gap-3 md:gap-4">
      {services.map(s => (
        <article class="card card-hover p-7 md:p-8 bg-[var(--color-paper)] flex flex-col">
          <h3 class="text-lg md:text-xl">{s.title}</h3>
          <ul class="mt-5 space-y-2.5 flex-grow">
            {s.items.map(it => (
              <li class="flex gap-2.5 items-start text-[var(--color-ink-soft)]">
                <span class="text-[var(--color-axxaz-navy)] mt-1.5 flex-shrink-0 w-1 h-1 rounded-full bg-current"></span>
                <span class="text-sm leading-relaxed">{it}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- VAKGEBIEDEN GRID -->
<section class="section">
  <div class="container-x">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
      <div class="max-w-xl">
        <div class="eyebrow">{t('vak.kicker')}</div>
        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl">{t('vak.title')}</h2>
      </div>
      <a href={localizePath(lang, '/vacatures')} class="btn btn-outline btn-sm">
        {t('cta.alleVacatures')}
        <Icon name="arrow-right" size={14} stroke={2.25} />
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-3">
      {vakgebieden.map(v => (
        <a href={localizePath(lang, `/vacatures?cat=${v.slug}`)}
           class="group flex items-center justify-between gap-4 rounded-xl border border-[var(--color-line)] bg-white px-5 py-5 hover:border-[var(--color-axxaz-navy)] hover:shadow-[0_8px_24px_-8px_rgba(14,26,61,0.15)] hover:-translate-y-0.5 transition-all duration-300">
          <div class="flex items-center gap-4 min-w-0">
            <span class="w-11 h-11 rounded-xl bg-[var(--color-axxaz-mist)] inline-flex items-center justify-center text-[var(--color-axxaz-navy)] flex-shrink-0 group-hover:bg-[var(--color-spark)] group-hover:text-white transition-colors">
              <Icon name={v.icon} size={20} />
            </span>
            <div class="min-w-0">
              <div class="font-semibold leading-tight truncate">{vakLabels[v.slug] ?? v.name}</div>
              <div class="text-xs text-[var(--color-ink-mute)] mt-0.5 font-mono">{t('vak.count').replace('{n}', String(v.count))}</div>
            </div>
          </div>
          <Icon name="arrow-up-right" size={16} stroke={2} class="text-[var(--color-ink-mute)] group-hover:text-[var(--color-spark)] flex-shrink-0 transition-colors" />
        </a>
      ))}
    </div>
  </div>
</section>

<!-- TEST CENTER -->
<section class="border-t border-[var(--color-line)]">
  <div class="container-x py-20 md:py-28 lg:py-32 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    <div>
      <div class="eyebrow eyebrow-dark">{t('tc.kicker')}</div>
      <h2 class="mt-5 text-3xl md:text-4xl lg:text-5xl">{t('tc.title')}</h2>
      <p class="mt-6 text-[var(--color-ink-soft)] leading-relaxed text-lg">{t('tc.sub')}</p>
      <ul class="mt-10 space-y-4">
        {tcBullets.map(item => (
          <li class="flex gap-3.5 text-[var(--color-ink)]">
            <span class="text-[var(--color-spark)] mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-[var(--color-spark)]/12 inline-flex items-center justify-center"><Icon name="check" size={14} stroke={2.5} /></span>
            <span class="leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
      <a href={localizePath(lang, '/vak-en-lastestcentrum')} class="btn btn-primary btn-lg mt-10">
        {t('tc.cta')}
        <Icon name="arrow-right" size={16} stroke={2.5} />
      </a>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div class="img-zoom rounded-2xl">
        <img src="/img/site/welding-1.png" alt="" class="aspect-[3/4] object-cover w-full" loading="lazy"/>
      </div>
      <div class="img-zoom rounded-2xl translate-y-10">
        <img src="/img/site/workshop-2.jpg" alt="" class="aspect-[3/4] object-cover w-full" loading="lazy"/>
      </div>
    </div>
  </div>
</section>

<!-- VACATURES STRIP -->
<section class="section">
  <div class="container-x">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl max-w-xl">{t('spoed.title')}</h2>
      <a href={localizePath(lang, '/vacatures')} class="btn btn-outline">
        {t('cta.alleVacatures')}
        <Icon name="arrow-right" size={14} stroke={2.25} />
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {urgentVacs.map(v => (
        <a href={localizePath(lang, `/vacatures/${v.slug}`)} class="card card-hover group p-7 flex flex-col">
          <div class="flex items-center justify-between gap-2 mb-5">
            <span class="chip chip-spark"><Icon name="flame" size={11} stroke={2} /> {t('spoed.urgent')}</span>
            <span class="text-xs text-[var(--color-ink-mute)] inline-flex items-center gap-1"><Icon name="pin" size={12} stroke={2} />{v.location}</span>
          </div>
          <h3 class="text-xl leading-snug group-hover:text-[var(--color-axxaz-navy)] transition-colors">{v.title}</h3>
          <p class="mt-3 text-sm flex-grow truncate-3">{v.summary}</p>
          <div class="mt-6 pt-5 border-t border-[var(--color-line)] flex items-center justify-between text-sm">
            <span class="font-semibold text-[var(--color-axxaz-navy)] font-mono">{v.salary}</span>
            <span class="w-8 h-8 rounded-full bg-[var(--color-axxaz-mist)] inline-flex items-center justify-center text-[var(--color-axxaz-navy)] group-hover:bg-[var(--color-spark)] group-hover:text-white transition-colors"><Icon name="arrow-right" size={14} stroke={2.5} /></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- REVIEWS BLOCK, featured quote -->
<section class="section border-t border-[var(--color-line)]">
  <div class="container-x">
    <div class="grid lg:grid-cols-[auto_1fr] gap-12 lg:gap-20 items-center max-w-5xl">
      <div class="lg:max-w-[200px]">
        <div class="eyebrow">{t('rev.kicker')}</div>
        <div class="mt-5 flex items-baseline gap-2">
          <div class="stat-num text-6xl md:text-7xl !text-[var(--color-axxaz-navy)]">{reviewSummary.google}</div>
          <div class="text-2xl text-[var(--color-ink-mute)] font-mono">/5</div>
        </div>
        <div class="flex gap-0.5 mt-3">
          {[1,2,3,4,5].map(s => (
            <Icon name="star" size={18} class="text-[var(--color-ember)] fill-[var(--color-ember)]" stroke={1.5} />
          ))}
        </div>
        <p class="mt-4 text-xs text-[var(--color-ink-soft)]">{reviewSummary.googleCount} reviews op Google</p>
      </div>
      <figure>
        <p class="text-2xl md:text-3xl lg:text-4xl !text-[var(--color-axxaz-navy-deep)] leading-tight tracking-tight" style="font-family:Manrope,sans-serif">"{reviews[0].text}"</p>
        <figcaption class="mt-7 flex items-center gap-3 text-sm">
          <div class="w-10 h-10 rounded-full bg-[var(--color-axxaz-mist)] inline-flex items-center justify-center text-[var(--color-axxaz-navy)] font-bold text-xs">{reviews[0].name.split(' ').map(w => w[0]).slice(0, 2).join('')}</div>
          <div>
            <div class="font-semibold text-[var(--color-ink)]">{reviews[0].name}</div>
            <div class="text-[var(--color-ink-mute)] text-xs">{reviews[0].role}</div>
          </div>
          <a href="#" class="ml-auto text-[var(--color-spark)] hover:text-[var(--color-spark-deep)] font-semibold text-sm inline-flex items-center gap-1">{t('rev.all')} <Icon name="arrow-right" size={13} stroke={2.5} /></a>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- FOUNDERS -->
<section class="section">
  <div class="container-x">
    <div class="grid lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-20 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl">{t('founders.title')}</h2>
        <p class="mt-6 leading-relaxed text-base md:text-lg">{t('founders.sub').replace('{year}', String(site.founded))}</p>
        <a href={localizePath(lang, '/wie-wij-zijn')} class="btn btn-primary mt-9">{t('cta.naarOnsTeam')}</a>
      </div>
      <div class="relative">
        <div class="img-zoom rounded-2xl shadow-[0_24px_60px_-20px_rgba(14,26,61,0.25)]">
          <img src="/img/team/founders-duo.jpg" alt="Sem Goddijn & Rody Sinke" class="aspect-[4/3] object-cover w-full" loading="lazy" />
        </div>
        <div class="absolute -bottom-6 -left-6 bg-white border border-[var(--color-line)] rounded-xl p-5 max-w-[280px] hidden md:block shadow-[0_16px_40px_-12px_rgba(14,26,61,0.2)]">
          <div class="text-xs uppercase tracking-widest text-[var(--color-spark)] font-bold">Sem & Rody</div>
          <div class="mt-1.5 font-semibold text-sm leading-snug">{t('founders.tag.role')} · {t('founders.tag.years')}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- COMMUNITY -->
<section class="section border-t border-[var(--color-line)]">
  <div class="container-x">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
      <div class="max-w-xl">
        <div class="eyebrow eyebrow-dark">{t('comm.kicker')}</div>
        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl">{t('comm.title')}</h2>
        <p class="mt-5 text-[var(--color-ink-soft)] leading-relaxed">{t('comm.sub')}</p>
      </div>
      <a href={localizePath(lang, '/community')} class="btn btn-outline">{t('comm.feed')}</a>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {facebookFeed.slice(0, 2).map(p => (
        <article class="rounded-2xl bg-white border border-[var(--color-line)] overflow-hidden flex flex-col hover:border-[var(--color-axxaz-navy)] hover:-translate-y-0.5 hover:shadow-[0_24px_60px_-24px_rgba(14,26,61,0.2)] transition-all duration-300">
          <div class="img-zoom">
            <img src={p.image} alt="" class="w-full aspect-[16/10] object-cover" loading="lazy" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center gap-2.5 text-xs text-[var(--color-ink-mute)]">
              <Icon name="facebook" size={14} class="text-[#1877F2]" />
              <span class="font-semibold">Facebook</span>
              <span>·</span>
              <time>{p.date}</time>
            </div>
            <h3 class="mt-3 text-base font-semibold leading-snug">{p.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-ink-soft)] truncate-3 flex-grow">{p.excerpt}</p>
            <div class="mt-5 pt-4 border-t border-[var(--color-line)] flex gap-5 text-xs text-[var(--color-ink-mute)]">
              <span class="inline-flex items-center gap-1.5"><Icon name="heart" size={12} stroke={2} /> {p.likes}</span>
              <span class="inline-flex items-center gap-1.5"><Icon name="comment" size={12} stroke={2} /> {p.comments}</span>
            </div>
          </div>
        </article>
      ))}
      <article class="rounded-2xl bg-white border border-[var(--color-line)] overflow-hidden flex flex-col hover:border-[var(--color-axxaz-navy)] hover:-translate-y-0.5 hover:shadow-[0_24px_60px_-24px_rgba(14,26,61,0.2)] transition-all duration-300">
        <div class="p-6 flex-grow">
          <div class="flex items-center gap-2.5 text-xs text-[var(--color-ink-mute)]">
            <Icon name="linkedin" size={14} class="text-[#0A66C2]" />
            <span class="font-semibold">LinkedIn</span>
            <span>·</span>
            <time>{linkedinFeed[0].date}</time>
          </div>
          <h3 class="mt-3 text-base font-semibold leading-snug">{linkedinFeed[0].title}</h3>
          <p class="mt-2 text-sm text-[var(--color-ink-soft)] truncate-4">{linkedinFeed[0].excerpt}</p>
          <div class="mt-5 pt-4 border-t border-[var(--color-line)] flex gap-5 text-xs text-[var(--color-ink-mute)]">
            <span class="inline-flex items-center gap-1.5"><Icon name="heart" size={12} stroke={2} /> {linkedinFeed[0].likes}</span>
            <span class="inline-flex items-center gap-1.5"><Icon name="comment" size={12} stroke={2} /> {linkedinFeed[0].comments}</span>
          </div>
        </div>
        <a href={localizePath(lang, '/community')} class="px-6 py-4 bg-[var(--color-paper)] border-t border-[var(--color-line)] hover:bg-[var(--color-axxaz-mist)]/40 transition-colors flex items-center justify-between text-sm">
          <span class="font-semibold">2 {lang === 'nl' ? 'jaar partnership' : 'years partnership'} Damen</span>
          <span class="text-[var(--color-spark)] inline-flex items-center gap-1.5 font-semibold">{t('cta.lezen')} <Icon name="arrow-right" size={14} stroke={2.25} /></span>
        </a>
      </article>
    </div>
  </div>
</section>

<!-- CASES PREVIEW -->
<section class="section border-t border-[var(--color-line)]" data-reveal>
  <div class="container-x">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
      <h2 class="text-3xl md:text-4xl lg:text-5xl">{t('cases.title')}</h2>
      <a href={localizePath(lang, '/cases')} class="text-[var(--color-spark)] hover:text-[var(--color-spark-deep)] font-semibold inline-flex items-center gap-1.5 text-sm">{t('cases.back')} <Icon name="arrow-right" size={14} stroke={2.25} /></a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {cases.map(cs => (
        <a href={localizePath(lang, `/cases/${cs.slug}`)} class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line)] bg-white hover:border-[var(--color-axxaz-navy)] hover:-translate-y-1 hover:shadow-[0_24px_60px_-24px_rgba(14,26,61,0.2)] transition-all duration-300">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img src={cs.cover} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4 text-white">
              <div class="text-[10px] uppercase tracking-widest font-bold opacity-90">{cs.industry} · {cs.location}</div>
              <div class="font-bold mt-1 truncate">{cs.client}</div>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-lg leading-snug group-hover:text-[var(--color-axxaz-navy)] transition-colors">{lang === 'en' ? cs.titleEn : cs.titleNl}</h3>
            <p class="mt-3 text-sm flex-grow truncate-3">{lang === 'en' ? cs.excerptEn : cs.excerptNl}</p>
            <div class="mt-5 inline-flex items-center gap-1.5 font-semibold text-sm text-[var(--color-spark)]">
              {t('cases.cta')} <Icon name="arrow-right" size={13} stroke={2.5} />
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


