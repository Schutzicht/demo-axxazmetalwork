---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const vakgebieden = ['Lassen MIG/MAG','Lassen TIG','Pijpfitten','Constructiebankwerk','Plaatwerk/IJzerwerk','CNC verspanen','Apparatenbouw','Monteur metaal','Anders'];
const talen = ['Nederlands','English','Deutsch','Polski','Tagalog','Tiếng Việt','Bahasa Indonesia','বাংলা','Română','Magyar'];
const certs = ['VCA basis','VCA VOL','MIG/MAG procedure','TIG procedure','NEN 3140','EVC','BHV','Heftruck'];
---
<PageHero
  kicker={t('cta.openSollicitatie')}
  title={t('soll.title')}
  sub={t('soll.sub')}
/>

<section class="section-tight">
  <div class="container-x grid lg:grid-cols-[1fr_340px] gap-10">
    <form id="open-sol" class="space-y-8 max-w-2xl"
          onsubmit="event.preventDefault();document.getElementById('done')?.classList.remove('hidden');document.getElementById('open-sol')?.classList.add('hidden');window.scrollTo({top:0,behavior:'smooth'});">

      <div>
        <h3 class="text-lg mb-5">{t('soll.persoonlijk')}</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <label>
            <span class="field-label">{t('soll.voornaam')} *</span>
            <input required class="field" />
          </label>
          <label>
            <span class="field-label">{t('soll.achternaam')} *</span>
            <input required class="field" />
          </label>
          <label>
            <span class="field-label">{t('soll.email')} *</span>
            <input required type="email" class="field" />
          </label>
          <label>
            <span class="field-label">{t('soll.tel')} *</span>
            <input required type="tel" class="field" />
          </label>
          <label>
            <span class="field-label">{t('soll.huidig')} *</span>
            <input required placeholder={t('soll.huidigPh')} class="field" />
          </label>
          <label>
            <span class="field-label">{t('soll.oorsprong')}</span>
            <input placeholder={t('soll.oorsprongPh')} class="field" />
          </label>
        </div>
      </div>

      <div>
        <h3 class="text-lg mb-5">{t('soll.vakgebied')}</h3>
        <fieldset>
          <legend class="sr-only">{t('soll.vakgebied')}</legend>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {vakgebieden.map(s => (
              <label class="cursor-pointer flex items-center gap-2 rounded-lg border border-[var(--color-line)] px-3.5 py-2.5 text-sm hover:border-[var(--color-axxaz-navy)] has-checked:border-[var(--color-axxaz-navy)] has-checked:bg-[var(--color-axxaz-mist)] transition-colors">
                <input type="checkbox" class="accent-[var(--color-axxaz-navy)]" />
                <span>{s}</span>
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <div>
        <label>
          <span class="field-label">{t('soll.ervaring')}</span>
          <select class="field">
            <option>0 – 1</option><option>1 – 3</option><option>3 – 5</option><option>5 – 10</option><option>10+</option>
          </select>
        </label>
      </div>

      <div>
        <h3 class="text-lg mb-5">{t('soll.talen')}</h3>
        <fieldset>
          <legend class="sr-only">{t('soll.talen')}</legend>
          <div class="flex flex-wrap gap-2">
            {talen.map(l => (
              <label class="cursor-pointer inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3.5 py-1.5 text-sm hover:border-[var(--color-axxaz-navy)] has-checked:border-[var(--color-axxaz-navy)] has-checked:bg-[var(--color-axxaz-mist)] transition-colors">
                <input type="checkbox" class="accent-[var(--color-axxaz-navy)]" />
                {l}
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <div>
        <h3 class="text-lg mb-5">{t('soll.certs')}</h3>
        <fieldset>
          <legend class="sr-only">{t('soll.certs')}</legend>
          <div class="flex flex-wrap gap-2">
            {certs.map(l => (
              <label class="cursor-pointer inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3.5 py-1.5 text-sm hover:border-[var(--color-axxaz-navy)] has-checked:border-[var(--color-axxaz-navy)] has-checked:bg-[var(--color-axxaz-mist)] transition-colors">
                <input type="checkbox" class="accent-[var(--color-axxaz-navy)]" />
                {l}
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <div>
        <label>
          <span class="field-label">{t('soll.motivatie')}</span>
          <textarea rows="4" class="field"></textarea>
        </label>
      </div>

      <div>
        <span class="field-label">{t('soll.cv')}</span>
        <label class="flex items-center gap-3 rounded-lg border border-dashed border-[var(--color-line)] px-4 py-5 cursor-pointer hover:border-[var(--color-axxaz-navy)] hover:bg-[var(--color-axxaz-mist)]/30 transition-colors">
          <Icon name="upload" size={20} class="text-[var(--color-ink-mute)]" />
          <div class="flex-grow">
            <div class="text-sm font-medium">{t('soll.cvSub')}</div>
            <div class="text-xs text-[var(--color-ink-mute)] mt-0.5">{t('soll.cvHint')}</div>
          </div>
          <input type="file" accept=".pdf,.doc,.docx" class="sr-only" />
        </label>
      </div>

      <label class="flex items-start gap-2.5 text-sm text-[var(--color-ink-soft)]">
        <input type="checkbox" required class="mt-1 accent-[var(--color-axxaz-navy)]" />
        <span>{t('soll.akkoord')}</span>
      </label>

      <button class="btn btn-primary btn-lg">
        {t('soll.send')}
        <Icon name="send" size={16} stroke={2} />
      </button>
    </form>

    <div id="done" class="hidden card p-10 text-center">
      <div class="w-14 h-14 mx-auto rounded-full bg-[var(--color-axxaz-mist)] flex items-center justify-center text-[var(--color-axxaz-navy)]">
        <Icon name="check" size={28} stroke={2.5} />
      </div>
      <h3 class="mt-5 text-2xl">{t('soll.thanks')}</h3>
      <p class="mt-3">{t('soll.thanksSub')}</p>
    </div>

    <aside class="space-y-5 lg:sticky lg:top-32 self-start">
      <div class="card p-6">
        <h4 class="font-semibold uppercase text-xs tracking-widest text-[var(--color-ink-mute)]">{t('soll.flow')}</h4>
        <ol class="mt-5 space-y-4">
          <li class="flex gap-3"><span class="num-badge">1</span><span class="text-sm pt-1.5 leading-relaxed">{t('soll.flow1')}</span></li>
          <li class="flex gap-3"><span class="num-badge">2</span><span class="text-sm pt-1.5 leading-relaxed">{t('soll.flow2')}</span></li>
          <li class="flex gap-3"><span class="num-badge">3</span><span class="text-sm pt-1.5 leading-relaxed">{t('soll.flow3')}</span></li>
          <li class="flex gap-3"><span class="num-badge num-badge-spark">4</span><span class="text-sm pt-1.5 leading-relaxed font-semibold text-[var(--color-ink)]">{t('soll.flow4')}</span></li>
        </ol>
      </div>
      <div class="card p-6 bg-[var(--color-axxaz-navy-deep)] text-white !border-transparent">
        <h4 class="font-semibold uppercase text-xs tracking-widest text-white/60">{t('soll.altCall')}</h4>
        <p class="mt-3 text-sm text-white/80 leading-relaxed">{t('soll.altCallSub')}</p>
      </div>
    </aside>
  </div>
</section>
