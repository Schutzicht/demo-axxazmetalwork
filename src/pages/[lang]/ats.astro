---
import Layout from '../../layouts/Layout.astro';
import AtsContent from '../../sections/AtsContent.astro';
import { ui, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(ui) as Lang[]).filter(l => l !== 'nl').map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---
<Layout title="ATS · Applicant Tracking" hideTopBar>
  <AtsContent lang={lang} />
</Layout>
