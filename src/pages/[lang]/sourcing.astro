---
import Layout from '../../layouts/Layout.astro';
import SourcingContent from '../../sections/SourcingContent.astro';
import { ui, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(ui) as Lang[]).filter(l => l !== 'nl').map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---
<Layout title="Sourcing">
  <SourcingContent lang={lang} />
</Layout>
