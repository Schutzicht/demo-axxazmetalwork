---
import Layout from '../../layouts/Layout.astro';
import WerkgeversContent from '../../sections/WerkgeversContent.astro';
import { ui, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(ui) as Lang[]).filter(l => l !== 'nl').map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---
<Layout title="For employers">
  <WerkgeversContent lang={lang} />
</Layout>
