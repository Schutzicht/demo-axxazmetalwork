---
import Layout from '../../layouts/Layout.astro';
import OpenSollicitatieContent from '../../sections/OpenSollicitatieContent.astro';
import { ui, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(ui) as Lang[]).filter(l => l !== 'nl').map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---
<Layout title="Open application">
  <OpenSollicitatieContent lang={lang} />
</Layout>
