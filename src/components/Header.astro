---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import LangSwitcher from './LangSwitcher.astro';
import { useTranslations, localizePath } from '../i18n/utils';
import { site } from '../data/site';
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang; currentPath: string }
const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const tel = site.phoneOffice.replace(/\s/g, '');

type IconName = 'briefcase' | 'send' | 'shield-check' | 'users' | 'cog' | 'globe' | 'badge-check' | 'tool';

const navTree: Array<
  | { type: 'group'; label: string; items: Array<{ href: string; label: string; desc: string; icon: IconName }> }
  | { type: 'link'; href: string; label: string }
> = [
  {
    type: 'group',
    label: t('duo.werk.kicker'), // "Voor vakmensen"
    items: [
      { href: '/vacatures',              label: t('nav.vacatures'),       desc: 'Alle openstaande functies',     icon: 'briefcase' },
      { href: '/open-sollicitatie',      label: t('cta.openSollicitatie'),desc: 'Geen passende vacature?',       icon: 'send' },
      { href: '/vak-en-lastestcentrum',  label: t('nav.lastest'),         desc: 'Tholen, eigen testcentrum',     icon: 'shield-check' },
      { href: '/community',              label: t('nav.community'),       desc: 'Onze metaalclub',               icon: 'users' },
    ],
  },
  {
    type: 'group',
    label: t('duo.personeel.kicker'), // "Voor opdrachtgevers"
    items: [
      { href: '/werkgevers',  label: t('nav.werkgevers'),    desc: '4 manieren van samenwerken',  icon: 'cog' },
      { href: '/sourcing',    label: t('nav.sourcing'),      desc: '10 EU + 5 AZ vestigingen',    icon: 'globe' },
      { href: '/cases',       label: t('nav.cases'),         desc: 'Echte verhalen + cijfers',    icon: 'badge-check' },
      { href: '/certificaten',label: t('nav.certificaten'),  desc: 'Downloads + audits',          icon: 'tool' },
    ],
  },
  { type: 'link', href: '/wie-wij-zijn', label: t('nav.wieZijnWij') },
];
---

<header id="site-header" class="sticky top-0 z-40 smart-header" data-scrolled="false" data-at-top="true">
  <div class="container-x flex items-center gap-4 lg:gap-6 py-3.5" id="header-inner">
    <Logo height={28} />

    <nav class="hidden lg:flex items-center gap-0.5 ml-auto text-[0.875rem]">
      {navTree.map(item => {
        if (item.type === 'link') {
          const href = localizePath(lang, item.href);
          const isActive = currentPath === href || currentPath === href + '/';
          return (
            <a href={href}
               data-active={isActive}
               class={`nav-link relative px-3 py-2 font-medium transition-colors ${isActive ? 'text-[var(--color-axxaz-navy)]' : 'text-[var(--color-ink-soft)] hover:text-[var(--color-axxaz-navy)]'}`}>
              {item.label}
            </a>
          );
        }
        const isGroupActive = item.items.some(sub => currentPath.includes(sub.href));
        return (
          <div class="nav-dropdown-trigger">
            <button
              type="button"
              class={`inline-flex items-center gap-1 px-3 py-2 font-medium transition-colors rounded-md ${isGroupActive ? 'text-[var(--color-axxaz-navy)]' : 'text-[var(--color-ink-soft)] hover:text-[var(--color-axxaz-navy)]'}`}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {item.label}
              <Icon name="chevron-down" size={14} stroke={2} class="opacity-60 group-hover:rotate-180 transition-transform" />
            </button>
            <div class="nav-dropdown-bridge"></div>
            <div class="nav-dropdown-panel" role="menu">
              {item.items.map(sub => (
                <a href={localizePath(lang, sub.href)} class="nav-dropdown-item" role="menuitem">
                  <span class="nav-dropdown-icon"><Icon name={sub.icon} size={16} stroke={1.75} /></span>
                  <span class="min-w-0">
                    <span class="block text-[var(--color-ink)] font-semibold leading-tight">{sub.label}</span>
                    <span class="block text-xs text-[var(--color-ink-mute)] mt-0.5">{sub.desc}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </nav>

    <div class="ml-auto lg:ml-0 flex items-center gap-2 sm:gap-3">
      <a href={`tel:${tel}`}
         class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-ink-soft)] hover:text-[var(--color-axxaz-navy)] transition-colors px-2"
         aria-label="Bel direct">
        <Icon name="phone" size={14} stroke={2.25} />
        <span class="hidden xl:inline">{site.phoneOfficeShort}</span>
      </a>
      <a href={localizePath(lang, '/ats')}
         class="hidden md:inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-bold tracking-[0.12em] uppercase text-[var(--color-spark)] hover:text-[var(--color-spark-deep)] hover:bg-[var(--color-spark)]/8 transition-colors"
         title="Applicant Tracking System (demo)">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-spark)]"></span>
        ATS
      </a>
      <LangSwitcher currentLang={lang} currentPath={currentPath} />
      <a href={localizePath(lang, '/contact')}
         class="hidden sm:inline-flex btn btn-primary btn-sm">
        {t('nav.contact')}
        <Icon name="arrow-right" size={14} stroke={2.25} />
      </a>
      <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2 text-[var(--color-axxaz-navy)] inline-flex items-center" aria-label="Menu">
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>
  <div id="header-progress" class="header-progress" aria-hidden="true"></div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-[var(--color-line)] bg-white max-h-[calc(100vh-60px)] overflow-y-auto">
    <nav class="container-x py-5 flex flex-col text-sm">
      {navTree.map(item => {
        if (item.type === 'link') {
          return (
            <a href={localizePath(lang, item.href)}
               class="px-3 py-2.5 rounded-md text-[var(--color-ink-soft)] hover:text-[var(--color-axxaz-navy)] hover:bg-[var(--color-axxaz-mist)] font-medium">
              {item.label}
            </a>
          );
        }
        return (
          <div class="mb-2">
            <div class="px-3 pt-3 pb-2 text-[10px] font-bold uppercase tracking-[0.18em] text-[var(--color-spark)]">{item.label}</div>
            {item.items.map(sub => (
              <a href={localizePath(lang, sub.href)}
                 class="flex items-center gap-3 px-3 py-2.5 rounded-md text-[var(--color-ink-soft)] hover:text-[var(--color-axxaz-navy)] hover:bg-[var(--color-axxaz-mist)]">
                <span class="w-7 h-7 rounded-md bg-[var(--color-axxaz-mist)] inline-flex items-center justify-center text-[var(--color-axxaz-navy)] flex-shrink-0">
                  <Icon name={sub.icon} size={14} stroke={1.75} />
                </span>
                <span class="font-medium">{sub.label}</span>
              </a>
            ))}
          </div>
        );
      })}
      <div class="rule my-3"></div>
      <a href={localizePath(lang, '/contact')} class="px-3 py-2.5 rounded-md text-[var(--color-axxaz-navy)] font-semibold inline-flex items-center justify-between">
        {t('nav.contact')} <Icon name="arrow-right" size={14} stroke={2.25} />
      </a>
      <a href={`tel:${tel}`} class="px-3 py-2.5 rounded-md text-[var(--color-spark)] font-semibold inline-flex items-center gap-2"><Icon name="phone" size={14} stroke={2} />{site.phoneOfficeShort}</a>
      <a href={localizePath(lang, '/ats')} class="px-3 py-2.5 rounded-md text-[var(--color-spark-deep)] font-semibold inline-flex items-center gap-2 text-xs tracking-[0.12em] uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-spark)]"></span>ATS demo
      </a>
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const inner = document.getElementById('header-inner');
    const progress = document.getElementById('header-progress');
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!header || !inner) return;

    let ticking = false;

    const update = () => {
      const y = Math.max(0, window.scrollY);
      const docH = (document.documentElement.scrollHeight - window.innerHeight) || 1;
      const pct = Math.min(100, Math.max(0, (y / docH) * 100));

      const atTop = y <= 4;
      const scrolled = y > 8;
      header.dataset.atTop = String(atTop);
      header.dataset.scrolled = String(scrolled);

      if (progress) progress.style.width = pct + '%';

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    if (!(window as any).__headerScrollBound) {
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      (window as any).__headerScrollBound = true;
    }
    update();

    if (btn && !btn.dataset.bound) {
      btn.dataset.bound = 'true';
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        menu?.classList.toggle('hidden');
      });
    }
  }

  if (document.readyState !== 'loading') initHeader();
  else document.addEventListener('DOMContentLoaded', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>
