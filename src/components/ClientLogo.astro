---
interface Props {
  name: string;
  domain: string;
  slug: string;
  industry?: string;
}
const { name, domain, slug, industry } = Astro.props;
const initials = name.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();
// Source-priority chain (browser load + onerror):
// 1. Local file in /img/clients/{slug}.png — priority override (drop logo-bestanden hier)
// 2. Clearbit Logo CDN (gratis, geen key) — fallback voor publieke domeinen
// 3. Wordmark fallback met initialen — als beide images falen
const localSrc = `/img/clients/${slug}.png`;
const clearbitSrc = `https://logo.clearbit.com/${domain}?size=120`;
---
<a href={`https://${domain}`} target="_blank" rel="noopener" class="client-logo group" title={`${name}${industry ? ' · ' + industry : ''}`} aria-label={name}>
  <div class="relative h-9 sm:h-10 md:h-11 w-auto flex items-center justify-center px-1">
    <img
      src={localSrc}
      alt={name}
      class="logo-img h-full w-auto max-w-[140px] object-contain grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
      data-clearbit={clearbitSrc}
      loading="lazy"
      decoding="async"
    />
    <div class="logo-fallback hidden absolute inset-0 px-3 rounded-md bg-[var(--color-axxaz-navy)] text-white font-extrabold text-sm items-center justify-center" style="font-family:Manrope,sans-serif">{initials}</div>
  </div>
</a>

<script>
  document.querySelectorAll<HTMLImageElement>('img.logo-img').forEach(img => {
    let stage = 0;
    img.addEventListener('error', () => {
      stage++;
      const clearbit = img.getAttribute('data-clearbit');
      if (stage === 1 && clearbit) {
        img.src = clearbit;
      } else {
        img.style.display = 'none';
        const fallback = img.parentElement?.querySelector<HTMLElement>('.logo-fallback');
        if (fallback) {
          fallback.classList.remove('hidden');
          fallback.classList.add('flex');
        }
      }
    });
  });
</script>
