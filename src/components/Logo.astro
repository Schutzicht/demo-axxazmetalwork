---
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
interface Props { variant?: 'light' | 'dark'; class?: string; height?: number; lang?: Lang; href?: string }
const { variant = 'dark', class: className = '', height = 32, lang = 'nl' as Lang, href } = Astro.props;
// natural aspect 1545:340 ~ 4.544
const width = Math.round(height * 4.544);
const to = href ?? localizePath(lang, '/home');
---

<a href={to} class={`inline-flex items-center ${className}`} aria-label="AXXAZ Metalwork">
  <img
    src="/img/site/axxaz-logo.webp"
    alt="AXXAZ Metalwork"
    width={width}
    height={height}
    style={`height:${height}px;width:auto;${variant === 'light' ? 'filter:brightness(0) invert(1);' : ''}`}
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</a>
