---
import { languages, type Lang } from '../i18n/ui';
import { alternateLinks } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props { currentLang: Lang; currentPath: string; onDark?: boolean }
const { currentLang, currentPath, onDark = false } = Astro.props;
const links = alternateLinks(currentLang, currentPath);
---

<details class={`lang-switcher relative ${onDark ? 'on-dark' : ''}`}>
  <summary class="cursor-pointer list-none inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs font-semibold transition-colors hover:bg-[var(--color-axxaz-mist)] data-[on-dark=true]:hover:bg-white/10" data-on-dark={onDark}>
    <Icon name="globe" size={14} />
    <span class="tracking-wider">{currentLang.toUpperCase()}</span>
    <Icon name="chevron-down" size={12} class="opacity-60" />
  </summary>
  <div class="absolute right-0 mt-2 w-48 rounded-lg border border-[var(--color-line)] bg-white py-1.5 shadow-lg z-50">
    {links.map(({ lang, href }) => (
      <a href={href}
         class={`flex items-center justify-between px-3 py-2 text-sm transition-colors ${lang === currentLang ? 'text-[var(--color-axxaz-navy)] font-semibold bg-[var(--color-axxaz-mist)]' : 'text-[var(--color-ink-soft)] hover:bg-[var(--color-axxaz-mist)] hover:text-[var(--color-axxaz-navy)]'}`}>
        <span>{languages[lang].label}</span>
        <span class="text-[10px] tracking-widest font-mono opacity-60">{lang.toUpperCase()}</span>
      </a>
    ))}
  </div>
</details>

<style>
  .lang-switcher summary::-webkit-details-marker { display: none; }
  .lang-switcher.on-dark summary { color: rgba(255,255,255,0.85); }
  .lang-switcher.on-dark summary:hover { background: rgba(255,255,255,0.08); color: white; }
  .lang-switcher[open] summary { background: var(--color-axxaz-mist); color: var(--color-axxaz-navy); }
  .lang-switcher.on-dark[open] summary { background: rgba(255,255,255,0.12); color: white; }
</style>
