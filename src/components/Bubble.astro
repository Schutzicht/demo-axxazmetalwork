---
interface Props {
  name: string;
  role?: string;
  image?: string;
  size?: 'sm' | 'md' | 'lg';
}
const { name, role, image, size = 'md' } = Astro.props;
const sizes = { sm: 'w-20', md: 'w-28 sm:w-32', lg: 'w-36 sm:w-44' };
const initials = name.split(' ').map(p => p[0]).slice(0, 2).join('').toUpperCase();
---
<figure class="text-center">
  <div class={`bubble mx-auto ${sizes[size]}`}>
    {image && (
      <img src={image} alt={name} loading="lazy"
           onerror="this.parentElement.classList.add('no-image');this.remove();" />
    )}
    <div class="bubble-fallback">
      <span style="font-family:Manrope,sans-serif">{initials}</span>
    </div>
  </div>
  <figcaption class="mt-3 space-y-0.5">
    <div class="font-semibold text-[var(--color-ink)] text-sm">{name}</div>
    {role && <div class="text-xs text-[var(--color-ink-mute)]">{role}</div>}
  </figcaption>
</figure>

<style>
  .bubble-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-axxaz-navy);
    font-weight: 700;
    font-size: 1.25rem;
    background: var(--color-axxaz-mist);
    z-index: -1;
  }
  .bubble.no-image .bubble-fallback { z-index: 1; }
  .bubble img { position: relative; z-index: 2; }
</style>
