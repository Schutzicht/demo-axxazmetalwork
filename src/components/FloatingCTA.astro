---
import { site } from '../data/site';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import Icon from './Icon.astro';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const wa = site.whatsapp.replace(/[^0-9]/g, '');
const tel = site.phoneOffice.replace(/[^0-9+]/g, '');
---

<div class="fixed bottom-5 right-4 z-30 flex flex-col items-end gap-2.5">
  <a href={`https://wa.me/${wa}`} target="_blank" rel="noopener"
     class="inline-flex items-center gap-2 rounded-full bg-[#25D366] hover:bg-[#1da851] px-3.5 py-3 text-white shadow-lg transition-colors"
     aria-label="WhatsApp">
    <Icon name="whatsapp" size={18} />
    <span class="hidden sm:inline text-sm font-semibold">WhatsApp</span>
  </a>
  <a href={`tel:${tel}`}
     class="inline-flex items-center gap-2 rounded-full bg-[var(--color-axxaz-navy)] hover:bg-[var(--color-axxaz-navy-deep)] px-3.5 py-3 text-white shadow-lg transition-colors"
     aria-label="Bel ons">
    <Icon name="phone" size={18} stroke={2} />
    <span class="hidden sm:inline text-sm font-semibold">{t('cta.belOns')}</span>
  </a>
</div>
