---
import { site } from '../data/site';
import Icon from './Icon.astro';
import type { Lang } from '../i18n/ui';
interface Props { lang: Lang }
const wa = site.whatsapp.replace(/[^0-9]/g, '');
---
<a href={`https://wa.me/${wa}`} target="_blank" rel="noopener"
   class="fixed bottom-5 right-5 z-30 inline-flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] hover:bg-[#1da851] text-white shadow-[0_12px_32px_-8px_rgba(37,211,102,0.5)] hover:scale-110 transition-all duration-200"
   aria-label="WhatsApp">
  <Icon name="whatsapp" size={26} />
</a>
